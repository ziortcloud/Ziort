# ============================================================
# Ziort — Environment Variables Template
# Copy to .env.local for development. NEVER commit .env.local
#
# NEW SETUP ORDER:
#   1. Create Supabase project → fill SUPABASE + DATABASE_URL vars
#   2. Create Cloudflare R2 bucket → fill R2 vars
#   3. Create Resend account + domain → fill RESEND vars
#   4. Run: cd packages/db && npx tsx scripts/setup.ts
# ============================================================

# ──────────────────────────────────────────────────────────────
# SUPABASE — New project setup
# Dashboard: https://supabase.com/dashboard
# Project: ziort-prod   (create new — do NOT reuse old project)
# ──────────────────────────────────────────────────────────────

# Public (safe for browser — auth only)
NEXT_PUBLIC_SUPABASE_URL=https://YOUR_PROJECT_REF.supabase.co
NEXT_PUBLIC_SUPABASE_ANON_KEY=eyJhbGciOiJIUzI1NiIsInR5cCI6IkpXVCJ9...

# Server-only (bypasses RLS — NEVER expose to browser)
SUPABASE_SERVICE_ROLE_KEY=eyJhbGciOiJIUzI1NiIsInR5cCI6IkpXVCJ9...

# ──────────────────────────────────────────────────────────────
# PRISMA — Database connection strings
# Supabase → Project → Settings → Database → Connection string
#   DATABASE_URL  → "Transaction" mode (pooled, port 6543) — used at runtime
#   DIRECT_URL    → "Session" mode (direct, port 5432)    — used for migrations
# ──────────────────────────────────────────────────────────────

DATABASE_URL=postgresql://postgres.YOUR_PROJECT_REF:YOUR_DB_PASSWORD@aws-0-ap-south-1.pooler.supabase.com:6543/postgres?pgbouncer=true&connection_limit=1
DIRECT_URL=postgresql://postgres.YOUR_PROJECT_REF:YOUR_DB_PASSWORD@aws-0-ap-south-1.pooler.supabase.com:5432/postgres

# ──────────────────────────────────────────────────────────────
# CLOUDFLARE R2 — Object storage (S3-compatible API)
# Dashboard: https://dash.cloudflare.com → R2 → Create bucket: ziort-prod
# API token: R2 → Manage R2 API Tokens → Create with Object Read & Write
# Public URL: Bucket → Settings → Public R2.dev Subdomain (enable it)
# ──────────────────────────────────────────────────────────────

R2_ACCOUNT_ID=your_cloudflare_account_id
R2_ACCESS_KEY_ID=your_r2_access_key_id
R2_SECRET_ACCESS_KEY=your_r2_secret_access_key
R2_BUCKET_NAME=ziort-prod
R2_PUBLIC_URL=https://pub-YOUR_BUCKET_TOKEN.r2.dev

# ──────────────────────────────────────────────────────────────
# RESEND — Transactional email
# Dashboard: https://resend.com/api-keys
# Add & verify your sending domain (e.g. ziort.com) before using
# ──────────────────────────────────────────────────────────────

RESEND_API_KEY=re_your_resend_api_key
RESEND_FROM_EMAIL=noreply@ziort.com
RESEND_FROM_NAME=Ziort

# ──────────────────────────────────────────────────────────────
# SMS / WhatsApp (MSG91) — optional for OTP
# ──────────────────────────────────────────────────────────────

MSG91_API_KEY=your_msg91_api_key
MSG91_SENDER_ID=ZIORBT
MSG91_WHATSAPP_AUTH_KEY=your_wa_auth_key

# ──────────────────────────────────────────────────────────────
# APP
# ──────────────────────────────────────────────────────────────

NEXT_PUBLIC_APP_URL=http://localhost:3000
NEXT_PUBLIC_WEB_URL=http://localhost:5173
NEXT_PUBLIC_APP_NAME=Ziort
APP_SECRET=generate_a_32char_random_secret_here

# ──────────────────────────────────────────────────────────────
# CRON SECURITY — protects /api/v1/billing/cron/* routes on Vercel
# ──────────────────────────────────────────────────────────────

CRON_SECRET=generate_a_32char_random_secret_here

# ──────────────────────────────────────────────────────────────
# MONITORING — optional in dev
# ──────────────────────────────────────────────────────────────

SENTRY_DSN=
NEXT_PUBLIC_POSTHOG_KEY=
NEXT_PUBLIC_POSTHOG_HOST=https://app.posthog.com

# ──────────────────────────────────────────────────────────────
# PAYMENT GATEWAYS — future
# ──────────────────────────────────────────────────────────────

# RAZORPAY_KEY_ID=rzp_test_...
# RAZORPAY_KEY_SECRET=...
# STRIPE_SECRET_KEY=sk_test_...
# STRIPE_WEBHOOK_SECRET=whsec_...
