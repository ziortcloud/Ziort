// ============================================================
// Ziort — Prisma Schema
// Single source of truth for the entire platform.
// Database: PostgreSQL via Supabase
// Auth:     Supabase Auth (auth.users) — referenced by auth_user_id
// Storage:  Cloudflare R2 (URLs stored as text)
//
// Naming convention:
//   Tables   → snake_case with zi_ / product prefix (e.g. zi_entities, zpn_loans)
//   Models   → PascalCase (e.g. ZiEntity, ZpnLoan)
//   Fields   → camelCase in Prisma, snake_case via @@map / @map
// ============================================================

generator client {
  provider = "prisma-client-js"
  output   = "../src/generated/prisma"
}

datasource db {
  provider  = "postgresql"
  url       = env("DATABASE_URL")
  directUrl = env("DIRECT_URL")
}

// ============================================================
// ENUMS
// ============================================================

enum EntityType {
  sole_proprietor
  company
  partnership
  trust
  individual
}

enum MemberRole {
  owner
  co_owner
  partner
  manager
  staff
  custom
}

enum ContactType {
  CST
  SUP
  VND
  AGT
  PTR
}

enum SubscriptionPlan {
  trial
  solo
  plus
  pro
}

enum SubscriptionStatus {
  trial
  active
  paused
  grace
  cancelled
}

enum KycStatus {
  PENDING
  VERIFIED
  REJECTED
}

enum TransactionType {
  debit
  credit
  refund
  adjustment
}

enum TopupStatus {
  pending
  success
  failed
  refunded
}

enum AuditAction {
  CREATE
  UPDATE
  DELETE
  LOGIN
  LOGOUT
  REVEAL
  EXPORT
  APPROVE
  REJECT
  CANCEL
}

enum NotificationType {
  INFO
  SUCCESS
  WARNING
  ERROR
  ALERT
}

enum ScopeType {
  PLATFORM
  ENTITY
  BRANCH
  SUBSCRIPTION
}

// ZiPawn enums
enum LoanStatus {
  ACTIVE
  CLOSED
  CANCELLED
  AUCTIONED
  MIGRATED
}

enum LoanClosureReason {
  REPAID
  RENEWED
  AUCTIONED
  WRITTEN_OFF
}

enum TicketStatus {
  OPEN
  PARTIALLY_RELEASED
  FULLY_RELEASED
  CANCELLED
}

enum InterestBasis {
  daily
  monthly
}

// ZiFleet enums
enum VehicleStatus {
  AVAILABLE
  ON_TRIP
  MAINTENANCE
  INACTIVE
}

enum TripStatus {
  SCHEDULED
  IN_PROGRESS
  COMPLETED
  CANCELLED
}

// ZiLoad enums
enum LoadStatus {
  OPEN
  ASSIGNED
  IN_TRANSIT
  DELIVERED
  CANCELLED
}

enum BookingStatus {
  PENDING
  CONFIRMED
  CANCELLED
}

// ZiDriver enums
enum DriverStatus {
  AVAILABLE
  ON_DUTY
  INACTIVE
}

// ZiCare / ZiPulse enums
enum AppointmentStatus {
  SCHEDULED
  COMPLETED
  CANCELLED
  NO_SHOW
}

// ZiChit enums
enum ChitStatus {
  ACTIVE
  COMPLETED
  DISSOLVED
}

// ZiNeed enums
enum RequirementStatus {
  OPEN
  MATCHED
  CLOSED
  EXPIRED
}

enum DealStatus {
  PROPOSED
  NEGOTIATING
  ACCEPTED
  REJECTED
  COMPLETED
}

// ZiShop / ZiFood enums
enum OrderStatus {
  PENDING
  CONFIRMED
  PREPARING
  READY
  DELIVERED
  CANCELLED
}

// ZiLedger enums
enum EntryType {
  DEBIT
  CREDIT
}

// ZiPost enums
enum AdStatus {
  DRAFT
  ACTIVE
  PAUSED
  EXPIRED
}

// ============================================================
// CODE SEQUENCES — alpha-grow generator
// fn_next_code(prefix) → 'ZPNA01', 'ZPNA02' … 'ZPNZ99' → 'ZPNAA01'
// ============================================================

model ZiCodeSequence {
  id           String   @id @default(uuid()) @db.Uuid
  codePrefix   String   @unique @map("code_prefix")
  lastSequence String   @map("last_sequence")
  totalIssued  BigInt   @default(0) @map("total_issued")
  createdAt    DateTime @default(now()) @map("created_at")
  updatedAt    DateTime @default(now()) @updatedAt @map("updated_at")

  @@map("zi_code_sequences")
}

// ============================================================
// NATIONAL ID CONFIGURATION (country-level)
// ============================================================

model ZiNationalIdConfig {
  countryCode      String  @id @map("country_code")
  countryName      String  @map("country_name")
  individualIdName String? @map("individual_id_name")
  individualFormat String? @map("individual_format")
  businessIdName   String? @map("business_id_name")
  businessFormat   String? @map("business_format")
  storeRaw         Boolean @default(false) @map("store_raw")
  storeHash        Boolean @default(true) @map("store_hash")
  displayLast      Int     @default(6) @map("display_last")
  verifyApi        String? @map("verify_api")

  @@map("zi_national_id_config")
}

// ============================================================
// INDIVIDUALS — Universal person registry (ZU prefix → ZUA01)
// One record per real human. Permanent. Never deleted.
// auth_user_id links to Supabase auth.users
// ============================================================

model ZiIndividual {
  id                  String    @id @default(uuid()) @db.Uuid
  ziCode              String    @unique @map("zi_code")
  displayName         String    @map("display_name")
  countryCode         String    @default("IN") @map("country_code")
  nationalIdType      String?   @map("national_id_type")
  nationalIdHash      String?   @unique @map("national_id_hash")
  nationalIdLast6     String?   @map("national_id_last6")
  nationalIdVerified  Boolean   @default(false) @map("national_id_verified")
  authUserId          String?   @unique @db.Uuid @map("auth_user_id")
  avatarUrl           String?   @map("avatar_url")
  preferredLang       String    @default("en") @map("preferred_lang")
  isActive            Boolean   @default(true) @map("is_active")
  createdAt           DateTime  @default(now()) @map("created_at")
  lastSeenAt          DateTime? @map("last_seen_at")

  emails                ZiIndividualEmail[]
  mobiles               ZiIndividualMobile[]
  memberships           ZiMembership[]
  bizContactsLinked     ZiBizContact[]
  subscriptionsPrimary  ZiSubscription[]    @relation("SubPrimaryOwner")
  subscriptionsBilling  ZiSubscription[]    @relation("SubBillingOwner")
  topupRequests         ZiTopupRequest[]
  billingLogsCreated    ZiBillingLog[]
  auditLogsActor        ZiAuditLog[]
  notifications         ZiNotification[]    @relation("NotifTarget")

  @@index([authUserId])
  @@map("zi_individuals")
}

model ZiIndividualEmail {
  id              String    @id @default(uuid()) @db.Uuid
  individualId    String    @db.Uuid @map("individual_id")
  email           String
  isCurrent       Boolean   @default(true) @map("is_current")
  isVerified      Boolean   @default(false) @map("is_verified")
  verifiedAt      DateTime? @map("verified_at")
  becameCurrentAt DateTime  @default(now()) @map("became_current_at")
  replacedAt      DateTime? @map("replaced_at")

  individual ZiIndividual @relation(fields: [individualId], references: [id])

  @@unique([individualId, email])
  @@index([email])
  @@index([individualId])
  @@map("zi_individual_emails")
}

model ZiIndividualMobile {
  id              String    @id @default(uuid()) @db.Uuid
  individualId    String    @db.Uuid @map("individual_id")
  mobileHash      String    @unique @map("mobile_hash")
  mobileLast4     String    @map("mobile_last4")
  countryDialCode String    @map("country_dial_code")
  isCurrent       Boolean   @default(true) @map("is_current")
  isVerified      Boolean   @default(false) @map("is_verified")
  verifiedAt      DateTime? @map("verified_at")
  becameCurrentAt DateTime  @default(now()) @map("became_current_at")
  replacedAt      DateTime? @map("replaced_at")
  cooldownUntil   DateTime? @map("cooldown_until")

  individual ZiIndividual @relation(fields: [individualId], references: [id])

  @@index([mobileHash])
  @@index([individualId])
  @@map("zi_individual_mobiles")
}

// ============================================================
// ENTITIES — Business entity (ZE prefix → ZEA01)
// ============================================================

model ZiEntity {
  id                  String     @id @default(uuid()) @db.Uuid
  ziCode              String     @unique @map("zi_code")
  legalName           String     @map("legal_name")
  tradeName           String?    @map("trade_name")
  entityType          EntityType @map("entity_type")
  countryCode         String     @default("IN") @map("country_code")
  businessIdType      String?    @map("business_id_type")
  businessIdHash      String?    @map("business_id_hash")
  businessIdLast6     String?    @map("business_id_last6")
  businessIdVerified  Boolean    @default(false) @map("business_id_verified")
  city                String?
  state               String?
  logoUrl             String?    @map("logo_url")
  isActive            Boolean    @default(true) @map("is_active")
  createdAt           DateTime   @default(now()) @map("created_at")

  branches         ZiBranch[]
  subscriptions    ZiSubscription[]
  memberships      ZiMembership[]
  bizContacts      ZiBizContact[]
  wallet           ZiWallet?
  billingLogs      ZiBillingLog[]
  billingSnapshots ZiBillingSnapshot[]
  topupRequests    ZiTopupRequest[]
  auditLogs        ZiAuditLog[]
  appConfigs       ZiAppConfig[]
  notifications    ZiNotification[]
  roles            ZiRole[]

  @@map("zi_entities")
}

// ============================================================
// BRANCHES — Physical location / operational unit (ZBR → ZBRA01)
// ref_code = ZEA01ZBRA01 (globally unique)
// ============================================================

model ZiBranch {
  id          String   @id @default(uuid()) @db.Uuid
  ziCode      String   @map("zi_code")
  entityId    String   @db.Uuid @map("entity_id")
  refCode     String   @unique @map("ref_code")
  name        String
  address     String?
  city        String?
  state       String?
  countryCode String   @default("IN") @map("country_code")
  isPrimary   Boolean  @default(false) @map("is_primary")
  isActive    Boolean  @default(true) @map("is_active")
  createdAt   DateTime @default(now()) @map("created_at")

  entity      ZiEntity       @relation(fields: [entityId], references: [id])
  bizContacts ZiBizContact[]
  auditLogs   ZiAuditLog[]

  @@unique([entityId, ziCode])
  @@index([entityId])
  @@map("zi_branches")
}

// ============================================================
// SUBSCRIPTIONS — Entity × Product (e.g. ZPN → ZPNA01)
// ref_code = ZEA01ZPNA01 (globally unique)
// ============================================================

model ZiSubscription {
  id             String             @id @default(uuid()) @db.Uuid
  ziCode         String             @map("zi_code")
  entityId       String             @db.Uuid @map("entity_id")
  refCode        String             @unique @map("ref_code")
  productCode    String             @map("product_code")
  productName    String             @map("product_name")
  planType       SubscriptionPlan   @default(trial) @map("plan_type")
  status         SubscriptionStatus @default(trial)
  trialStart     DateTime?          @db.Date @map("trial_start")
  trialEnd       DateTime?          @db.Date @map("trial_end")
  billingStart   DateTime?          @db.Date @map("billing_start")
  isAnnual       Boolean            @default(false) @map("is_annual")
  maxUsers       Int?               @map("max_users")
  primaryOwnerId String?            @db.Uuid @map("primary_owner_id")
  billingOwnerId String?            @db.Uuid @map("billing_owner_id")
  createdAt      DateTime           @default(now()) @map("created_at")

  entity       ZiEntity      @relation(fields: [entityId], references: [id])
  primaryOwner ZiIndividual? @relation("SubPrimaryOwner", fields: [primaryOwnerId], references: [id])
  billingOwner ZiIndividual? @relation("SubBillingOwner", fields: [billingOwnerId], references: [id])
  bizContacts  ZiBizContact[]

  // Product tables (one per product)
  zpnSchemes     ZpnScheme[]
  zpnLoans       ZpnLoan[]
  zflVehicles    ZflVehicle[]
  zflTrips       ZflTrip[]
  zldLoads       ZldLoad[]
  zdrvDrivers    ZdrvDriver[]
  zdrvEngagements ZdrvEngagement[]
  zpulseAppts    ZpulseAppointment[]
  zndRequirements ZndRequirement[]
  zndDeals       ZndDeal[]
  zchtFunds      ZchtFund[]
  zcarePatients  ZcarePatient[]
  zcarePrescriptions ZcarePrescription[]
  zfoodOrders    ZfoodOrder[]
  zshpOrders     ZshpOrder[]
  zinvInvoices   ZinvInvoice[]
  zqtQuotes      ZqtQuote[]
  zrptReceipts   ZrptReceipt[]
  zldgEntries    ZldgEntry[]
  zpostAds       ZpostAd[]
  zscnDocuments  ZscnDocument[]
  zylYields      ZylYield[]
  zbldProjects   ZbldProject[]
  zptnPartnerships ZptnPartnership[]
  zcalcResults   ZcalcResult[]

  @@unique([entityId, ziCode])
  @@index([entityId])
  @@index([productCode])
  @@map("zi_subscriptions")
}

// ============================================================
// MEMBERSHIPS — Individual ↔ Entity link
// ref_code = ZEA01ZUA01 (entity + individual codes)
// ============================================================

model ZiMembership {
  id             String     @id @default(uuid()) @db.Uuid
  refCode        String     @unique @map("ref_code")
  entityId       String     @db.Uuid @map("entity_id")
  individualId   String     @db.Uuid @map("individual_id")
  role           MemberRole
  isPrimaryOwner Boolean    @default(false) @map("is_primary_owner")
  isBillingOwner Boolean    @default(false) @map("is_billing_owner")
  equityPercent  Decimal?   @db.Decimal(5, 2) @map("equity_percent")
  permissions    Json?
  branchAccess   Json?      @map("branch_access")
  invitedBy      String?    @db.Uuid @map("invited_by")
  isActive       Boolean    @default(true) @map("is_active")
  joinedAt       DateTime?  @map("joined_at")
  expiresAt      DateTime?  @map("expires_at")
  createdAt      DateTime   @default(now()) @map("created_at")

  entity     ZiEntity        @relation(fields: [entityId], references: [id])
  individual ZiIndividual    @relation(fields: [individualId], references: [id])
  memberRoles ZiMemberRole[]

  @@unique([entityId, individualId])
  @@index([entityId])
  @@index([individualId])
  @@map("zi_memberships")
}

// ============================================================
// BIZ CONTACTS — Customers / Suppliers / Vendors / Agents / Partners
// ref_code = ZEA01ZPNA01CSTA01
// ============================================================

model ZiBizContact {
  id             String      @id @default(uuid()) @db.Uuid
  ziCode         String      @map("zi_code")
  refCode        String      @unique @map("ref_code")
  entityId       String      @db.Uuid @map("entity_id")
  subscriptionId String      @db.Uuid @map("subscription_id")
  branchId       String?     @db.Uuid @map("branch_id")
  individualId   String?     @db.Uuid @map("individual_id")
  contactType    ContactType @map("contact_type")
  displayName    String      @map("display_name")
  mobileDisplay  String?     @map("mobile_display")
  emailDisplay   String?     @map("email_display")
  tags           Json?
  isVerified     Boolean     @default(false) @map("is_verified")
  isActive       Boolean     @default(true) @map("is_active")
  createdAt      DateTime    @default(now()) @map("created_at")

  entity       ZiEntity       @relation(fields: [entityId], references: [id])
  subscription ZiSubscription @relation(fields: [subscriptionId], references: [id])
  branch       ZiBranch?      @relation(fields: [branchId], references: [id])
  individual   ZiIndividual?  @relation(fields: [individualId], references: [id])

  // Product contact references
  zpnLoans  ZpnLoan[]

  @@unique([entityId, subscriptionId, contactType, ziCode])
  @@index([entityId])
  @@index([subscriptionId])
  @@index([individualId])
  @@map("zi_biz_contacts")
}

// ============================================================
// BILLING — Wallet / Log / Snapshot / Topup
// Balance stored in paise (₹1 = 100 paise) — no floats
// ============================================================

model ZiWallet {
  id           String   @id @default(uuid()) @db.Uuid
  entityId     String   @unique @db.Uuid @map("entity_id")
  balancePaise BigInt   @default(0) @map("balance_paise")
  currency     String   @default("INR")
  updatedAt    DateTime @default(now()) @updatedAt @map("updated_at")

  entity ZiEntity @relation(fields: [entityId], references: [id])

  @@index([entityId])
  @@map("zi_wallet")
}

model ZiBillingLog {
  id                String          @id @default(uuid()) @db.Uuid
  entityId          String          @db.Uuid @map("entity_id")
  transactionType   TransactionType @map("transaction_type")
  amountPaise       BigInt          @map("amount_paise")
  description       String
  refCode           String?         @map("ref_code")
  balanceAfterPaise BigInt          @map("balance_after_paise")
  createdAt         DateTime        @default(now()) @map("created_at")
  createdBy         String?         @db.Uuid @map("created_by")

  entity    ZiEntity      @relation(fields: [entityId], references: [id])
  createdByIndividual ZiIndividual? @relation(fields: [createdBy], references: [id])

  @@index([entityId])
  @@index([createdAt(sort: Desc)])
  @@map("zi_billing_log")
}

model ZiBillingSnapshot {
  id                    String   @id @default(uuid()) @db.Uuid
  entityId              String   @db.Uuid @map("entity_id")
  snapshotDate          DateTime @db.Date @map("snapshot_date")
  productCount          Int      @default(0) @map("product_count")
  activeUserCount       Int      @default(0) @map("active_user_count")
  branchCount           Int      @default(0) @map("branch_count")
  bundleDiscountPct     Decimal  @default(0) @db.Decimal(5, 2) @map("bundle_discount_pct")
  baseCostPaise         BigInt   @default(0) @map("base_cost_paise")
  discountPaise         BigInt   @default(0) @map("discount_paise")
  dailyCostPaise        BigInt   @default(0) @map("daily_cost_paise")
  notificationCostPaise BigInt   @default(0) @map("notification_cost_paise")
  totalCostPaise        BigInt   @default(0) @map("total_cost_paise")
  deducted              Boolean  @default(false)
  deductedAt            DateTime? @map("deducted_at")
  createdAt             DateTime @default(now()) @map("created_at")

  entity ZiEntity @relation(fields: [entityId], references: [id])

  @@unique([entityId, snapshotDate])
  @@index([entityId])
  @@index([snapshotDate(sort: Desc)])
  @@map("zi_billing_snapshot")
}

model ZiTopupRequest {
  id               String      @id @default(uuid()) @db.Uuid
  entityId         String      @db.Uuid @map("entity_id")
  individualId     String      @db.Uuid @map("individual_id")
  amountPaise      BigInt      @map("amount_paise")
  currency         String      @default("INR")
  gateway          String      @default("manual")
  gatewayOrderId   String?     @map("gateway_order_id")
  gatewayPaymentId String?     @map("gateway_payment_id")
  status           TopupStatus @default(pending)
  creditedAt       DateTime?   @map("credited_at")
  createdAt        DateTime    @default(now()) @map("created_at")

  entity     ZiEntity     @relation(fields: [entityId], references: [id])
  individual ZiIndividual @relation(fields: [individualId], references: [id])

  @@index([entityId])
  @@map("zi_topup_requests")
}

// ============================================================
// AUDIT LOGS — Immutable. Never update or delete.
// ============================================================

model ZiAuditLog {
  id           String      @id @default(uuid()) @db.Uuid
  entityId     String?     @db.Uuid @map("entity_id")
  branchId     String?     @db.Uuid @map("branch_id")
  actorId      String?     @db.Uuid @map("actor_id")
  action       AuditAction
  resourceType String      @map("resource_type")
  resourceId   String?     @map("resource_id")
  oldData      Json?       @map("old_data")
  newData      Json?       @map("new_data")
  metadata     Json?
  ipAddress    String?     @map("ip_address")
  userAgent    String?     @map("user_agent")
  createdAt    DateTime    @default(now()) @map("created_at")

  entity ZiEntity?     @relation(fields: [entityId], references: [id])
  branch ZiBranch?     @relation(fields: [branchId], references: [id])
  actor  ZiIndividual? @relation(fields: [actorId], references: [id])

  @@index([entityId, createdAt(sort: Desc)])
  @@index([resourceType, resourceId])
  @@index([actorId])
  @@map("zi_audit_logs")
}

// ============================================================
// APP CONFIGS — Feature flags & settings at any scope
// Ported from Zihive. Scoped to PLATFORM / ENTITY / BRANCH / SUBSCRIPTION.
// ============================================================

model ZiAppConfig {
  id        String    @id @default(uuid()) @db.Uuid
  scopeType ScopeType @map("scope_type")
  scopeId   String?   @db.Uuid @map("scope_id")
  entityId  String?   @db.Uuid @map("entity_id")
  key       String
  value     Json
  isPublic  Boolean   @default(false) @map("is_public")
  createdAt DateTime  @default(now()) @map("created_at")
  updatedAt DateTime  @updatedAt @map("updated_at")

  entity ZiEntity? @relation(fields: [entityId], references: [id])

  @@unique([scopeType, scopeId, key])
  @@index([scopeType, scopeId])
  @@map("zi_app_configs")
}

// ============================================================
// NOTIFICATIONS — In-app. Ported from Zihive.
// target_user_id references zi_individuals.id (the logged-in staff member)
// ============================================================

model ZiNotification {
  id           String           @id @default(uuid()) @db.Uuid
  entityId     String?          @db.Uuid @map("entity_id")
  targetUserId String           @db.Uuid @map("target_user_id")
  type         NotificationType @default(INFO)
  title        String
  body         String
  link         String?
  metadata     Json?
  readAt       DateTime?        @map("read_at")
  createdAt    DateTime         @default(now()) @map("created_at")

  entity     ZiEntity?     @relation(fields: [entityId], references: [id])
  targetUser ZiIndividual? @relation("NotifTarget", fields: [targetUserId], references: [id])

  @@index([targetUserId, readAt])
  @@index([entityId])
  @@map("zi_notifications")
}

// ============================================================
// RBAC — Roles / Permissions / Member Roles
// Ported from Zihive. System roles (isSystem=true) seeded at startup.
// ============================================================

model ZiRole {
  id          String   @id @default(uuid()) @db.Uuid
  entityId    String?  @db.Uuid @map("entity_id")
  name        String
  description String?
  isDefault   Boolean  @default(false) @map("is_default")
  isSystem    Boolean  @default(false) @map("is_system")
  createdAt   DateTime @default(now()) @map("created_at")
  updatedAt   DateTime @updatedAt @map("updated_at")

  entity      ZiEntity?          @relation(fields: [entityId], references: [id])
  permissions ZiRolePermission[]
  memberRoles ZiMemberRole[]

  @@unique([entityId, name])
  @@index([entityId])
  @@map("zi_roles")
}

model ZiPermission {
  code        String  @id
  description String?
  productCode String? @map("product_code")
  isCore      Boolean @default(true) @map("is_core")

  rolePermissions ZiRolePermission[]

  @@map("zi_permissions")
}

model ZiRolePermission {
  roleId     String @db.Uuid @map("role_id")
  permission String

  role ZiRole       @relation(fields: [roleId], references: [id], onDelete: Cascade)
  perm ZiPermission @relation(fields: [permission], references: [code], onDelete: Cascade)

  @@id([roleId, permission])
  @@map("zi_role_permissions")
}

model ZiMemberRole {
  id           String   @id @default(uuid()) @db.Uuid
  membershipId String   @db.Uuid @map("membership_id")
  roleId       String   @db.Uuid @map("role_id")
  branchId     String?  @db.Uuid @map("branch_id")
  createdAt    DateTime @default(now()) @map("created_at")

  membership ZiMembership @relation(fields: [membershipId], references: [id], onDelete: Cascade)
  role       ZiRole       @relation(fields: [roleId], references: [id], onDelete: Cascade)

  @@unique([membershipId, roleId, branchId])
  @@index([membershipId])
  @@map("zi_member_roles")
}

// ============================================================
// ██████████████████████████████████████████████████████████
//   PRODUCT SCHEMAS
// ██████████████████████████████████████████████████████████
// ============================================================

// ============================================================
// ZIPAWN — Gold Pawn & Pledge Loans (ZPN → ZPNA01)
// ============================================================

model ZpnScheme {
  id             String        @id @default(uuid()) @db.Uuid
  entityId       String        @db.Uuid @map("entity_id")
