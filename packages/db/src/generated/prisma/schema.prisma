  interestBasis    InterestBasis @default(daily) @map("interest_basis")
  ltvGold916       Decimal       @default(75.00) @map("ltv_gold_916") @db.Decimal(5, 2)
  ltvGold999       Decimal       @default(80.00) @map("ltv_gold_999") @db.Decimal(5, 2)
  ltvSilver        Decimal       @default(60.00) @map("ltv_silver") @db.Decimal(5, 2)
