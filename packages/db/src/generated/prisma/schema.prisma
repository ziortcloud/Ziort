  maxLoanPaise     BigInt        @default(100000000) @map("max_loan_paise")
  minTenureDays    Int?          @map("min_tenure_days")
  maxTenureDays    Int?          @map("max_tenure_days")
  penaltyEnabled   Boolean       @default(false) @map("penalty_enabled")
  penaltyGraceDays Int           @default(0) @map("penalty_grace_days")
  penaltyRate      Decimal       @default(0) @map("penalty_rate") @db.Decimal(5, 2)
  penaltyBasis     String        @default("flat") @map("penalty_basis")
  isActive         Boolean       @default(true) @map("is_active")
  createdAt        DateTime      @default(now()) @map("created_at")
  updatedAt        DateTime      @updatedAt @map("updated_at")

