  subscription ZiSubscription @relation(fields: [subscriptionId], references: [id])

  @@index([entityId])
  @@index([subscriptionId])
  @@map("zldg_entries")
}

// ============================================================
// ZIPOST — Advertisement platform (ZPST → ZPSTA01)
// ============================================================

model ZpostAd {
  id             String   @id @default(uuid()) @db.Uuid
  adCode         String   @unique @map("ad_code")
  entityId       String   @map("entity_id") @db.Uuid
  subscriptionId String   @map("subscription_id") @db.Uuid
  title          String
  description    String?
  mediaUrls      Json     @default("[]") @map("media_urls")
  targetCategory String?  @map("target_category")
  targetCity     String?  @map("target_city")
  budgetPaise    BigInt?  @map("budget_paise")
  startDate      DateTime @map("start_date") @db.Date
  endDate        DateTime @map("end_date") @db.Date
  status         AdStatus @default(DRAFT)
  impressions    Int      @default(0)
  clicks         Int      @default(0)
  createdAt      DateTime @default(now()) @map("created_at")
  updatedAt      DateTime @updatedAt @map("updated_at")

  subscription ZiSubscription @relation(fields: [subscriptionId], references: [id])

  @@index([entityId])
  @@map("zpost_ads")
}

