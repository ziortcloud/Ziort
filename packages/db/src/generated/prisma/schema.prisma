// ============================================================
// ZIYIELD — Agriculture produce tracking (ZYLD → ZYLDA01)
// ============================================================

model ZylYield {
  id              String    @id @default(uuid()) @db.Uuid
  yieldCode       String    @unique @map("yield_code")
  entityId        String    @map("entity_id") @db.Uuid
  subscriptionId  String    @map("subscription_id") @db.Uuid
  cropType        String    @map("crop_type")
  fieldName       String?   @map("field_name")
  areaAcres       Decimal?  @map("area_acres") @db.Decimal(10, 2)
  expectedKg      Decimal?  @map("expected_kg") @db.Decimal(10, 2)
  actualKg        Decimal?  @map("actual_kg") @db.Decimal(10, 2)
  harvestDate     DateTime? @map("harvest_date") @db.Date
  marketRatePaise BigInt?   @map("market_rate_paise")
  notes           String?
  createdAt       DateTime  @default(now()) @map("created_at")
  updatedAt       DateTime  @updatedAt @map("updated_at")

  subscription ZiSubscription @relation(fields: [subscriptionId], references: [id])

  @@index([entityId])
  @@map("zyl_yields")
}

