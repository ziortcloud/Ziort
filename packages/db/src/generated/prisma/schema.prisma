model ZrptReceipt {
  id             String   @id @default(uuid()) @db.Uuid
  receiptCode    String   @unique @map("receipt_code")
  entityId       String   @map("entity_id") @db.Uuid
  subscriptionId String   @map("subscription_id") @db.Uuid
  contactId      String?  @map("contact_id") @db.Uuid
  refCode        String?  @map("ref_code")
  amountPaise    BigInt   @map("amount_paise")
  paymentMode    String   @default("cash") @map("payment_mode")
  reference      String?
  pdfUrl         String?  @map("pdf_url")
  paidAt         DateTime @default(now()) @map("paid_at")
  createdAt      DateTime @default(now()) @map("created_at")

  subscription ZiSubscription @relation(fields: [subscriptionId], references: [id])

  @@index([entityId])
  @@map("zrpt_receipts")
}

// ============================================================
